{
    "version": "2.0.0",
    "tasks": [
        {
            "label": "build (Debug x64)",
            "command": "dotnet",
            "type": "process",
            "args": [
                "build",
                "${workspaceFolder}/GL Tech 2.1.sln",
                "-c",
                "Debug",
                "-p:Platform=x64"
            ],
            "problemMatcher": "$msCompile"
        },
        {
            "label": "build (Release x64)",
            "command": "dotnet",
            "type": "process",
            "args": [
                "build",
                "${workspaceFolder}/GL Tech 2.1.sln",
                "-c",
                "Release",
                "-p:Platform=x64"
            ],
            "problemMatcher": "$msCompile"
        },
        {
            "label": "publish",
            "command": "dotnet",
            "type": "process",
            "args": [
                "publish",
                "${workspaceFolder}/GL Tech 2.1.sln"
            ],
            "problemMatcher": "$msCompile"
        },
        {
            "label": "watch",
            "command": "dotnet",
            "type": "process",
            "args": [
                "watch",
                "run",
                "${workspaceFolder}/GL Tech 2.1.sln"
            ],
            "problemMatcher": "$msCompile"
        }
    ]
}
